# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leads_enrichment
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/leads_enrichment

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── OpenAI ──
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ── External Enrichment APIs ──
# Google News (via NewsAPI)
GOOGLE_NEWS_API_KEY=your-newsapi-key-here
GOOGLE_NEWS_API_URL=https://newsapi.org/v2/everything

# Lusha (Contact Enrichment)
LUSHA_API_KEY=your-lusha-api-key-here
LUSHA_API_URL=https://api.lusha.com/person

# Clearbit (Company Enrichment)
CLEARBIT_API_KEY=your-clearbit-api-key-here
CLEARBIT_API_URL=https://company.clearbit.com/v2/companies/find

# Hunter.io (Email Finder)
HUNTER_API_KEY=your-hunter-api-key-here
HUNTER_API_URL=https://api.hunter.io/v2/domain-search

# ── App ──
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production
